{
  "name": "rank-force",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "sst dev",
    "build": "tsc -p tsconfig.app.json && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "pnpm run lint --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "pnpm run format:check && pnpm run lint",
    "fix": "pnpm run format && pnpm run lint:fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "types:watch": "tsc --noEmit --watch -p tsconfig.app.json",
    "deploy": "sst deploy",
    "deploy:dev": "sst deploy",
    "deploy:prd": "sst deploy --stage=prd",
    "playwright": "playwright test",
    "playwright:ui": "pnpm run playwright --ui",
    "prepare": "husky"
  },
  "lint-staged": {
    "!(*.d).{ts,tsx}": [
      "eslint --fix --max-warnings 0 --report-unused-disable-directives",
      "prettier --write"
    ],
    "*.d.ts": "prettier --write",
    "*.{json,md,css,html,yml,yaml}": "prettier --write"
  },
  "dependencies": {
    "@automerge/automerge": "^3.2.5",
    "@automerge/automerge-repo": "^2.5.5",
    "@automerge/automerge-repo-network-broadcastchannel": "^2.5.5",
    "@automerge/automerge-repo-react-hooks": "^2.5.5",
    "@automerge/automerge-repo-storage-indexeddb": "^2.5.5",
    "@aws-sdk/client-dynamodb": "^3.598.0",
    "@aws-sdk/lib-dynamodb": "^3.598.0",
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-navigation-menu": "^1.1.4",
    "@radix-ui/react-radio-group": "^1.1.3",
    "@radix-ui/react-slider": "^1.1.2",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-tabs": "^1.0.4",
    "@tanstack/react-router": "^1.40.0",
    "aws-iot-device-sdk-v2": "^1.19.5",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "events": "^3.3.0",
    "lucide-react": "^0.395.0",
    "mqtt": "^5.15.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sst": "^4.12.2",
    "tailwind-merge": "^2.3.0",
    "tailwindcss-animate": "^1.0.7",
    "ulid": "^2.3.0",
    "usehooks-ts": "^3.1.0",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.1",
    "@tanstack/router-devtools": "^1.40.0",
    "@tanstack/router-plugin": "^1.39.13",
    "@testing-library/react": "^16.0.0",
    "@types/node": "^20.14.2",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "@vitejs/plugin-react-swc": "^3.5.0",
    "@vitest/ui": "^1.6.0",
    "autoprefixer": "^10.4.19",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.7",
    "fake-indexeddb": "^6.2.5",
    "husky": "^9.0.11",
    "jsdom": "^24.1.0",
    "lint-staged": "^16.4.0",
    "postcss": "^8.4.39",
    "prettier": "^3.3.2",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.2.2",
    "vite": "^5.3.1",
    "vite-plugin-top-level-await": "^1.6.0",
    "vite-plugin-wasm": "^3.6.0",
    "vitest": "^1.6.0"
  }
}
