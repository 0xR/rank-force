    "sst": "^3.0.33",
    "tailwind-merge": "^2.3.0",
    "tailwindcss-animate": "^1.0.7",
    "ulid": "^2.3.0",
    "usehooks-ts": "^3.1.0",
    "zustand": "^4.5.2"
